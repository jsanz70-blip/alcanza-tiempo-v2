# ============================================
# Configuración Integración BSale - Sistema de Tesorería
# ============================================
# Copia este archivo a .env y completa con tus credenciales

# API Key de BSale (obtener desde: https://app.bsale.com.co/developers/api)
BSALE_API_KEY=tu_api_key_aqui

# API Secret de BSale (opcional, para endpoints que lo requieran)
BSALE_API_SECRET=tu_api_secret_aqui

# Entorno a utilizar (dev/staging/production)
BSALE_ENVIRONMENT=dev

# URL base de la API (opcional, se configura automáticamente según entorno)
# BSALE_API_BASE_URL=https://api.bsale.com.co

# Intervalo de sincronización (en segundos) - para ejecución programada
# SYNC_INTERVAL=86400  # 24 horas

# ============================================
# Ejemplos de uso:
# ============================================
# Sincronizar fecha actual:
# node src/bin/integrate-bSale.js
#
# Sincronizar fecha específica:
# node src/bin/integrate-bSale.js 2024-12-15
#
# Forzar recarga (ignorar duplicados):
# node src/bin/integrate-bSale.js 2024-12-15 --force

# ============================================
# Documentación:
# ============================================
# - Sistema de Tesorería: docs/tesoreria.md
# - BSale API Docs: https://apidocs.bsale.com.co
# - Reglas de negocio: docs/integracion-ventas.md